pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "sruti321/node-react-app"
        DOCKER_TAG = "latest"
        DOCKER_CREDENTIALS = "docker-hub-credentials"
    }

    stages {
        stage('Clone Check') {
            steps {
                echo 'Repository cloned successfully!'
            }
        }

        stage('Install Backend Dependencies') {
            steps {
                dir('backend') {
                    bat 'npm install'
                }
            }
        }

        stage('Install Frontend Dependencies') {
            steps {
                dir('frontend') {
                    bat 'npm install'
                }
            }
        }

        stage('Run Backend Tests') {
            steps {
                dir('backend') {
                    bat 'npm test'
                }
            }
        }

        stage('Run Frontend Tests') {
            steps {
                dir('frontend') {
                    bat 'npm test'
                }
            }
        }

        stage('Build Frontend') {
            steps {
                dir('frontend') {
                    bat 'npm run build'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                bat "docker build -t %DOCKER_IMAGE%:%DOCKER_TAG% ."
            }
        }

        stage('Push Docker Image') {
            steps {
                script {
                    docker.withRegistry('', DOCKER_CREDENTIALS) {
                        bat "docker push %DOCKER_IMAGE%:%DOCKER_TAG%"
                    }
                }
            }
        }
    }

    post {
        success {
            mail to: 'samalsrutisucharita.com',
                 subject: "SUCCESS: Jenkins Pipeline",
                 body: "Pipeline executed successfully!"
        }
        failure {
            mail to: 'samalsrutisucharita.com',
                 subject: "FAILURE: Jenkins Pipeline",
                 body: "Pipeline failed. Check Jenkins logs."
        }
    }
}
