pipeline {
    agent any

    options {
        skipStagesAfterUnstable(false)
    }

    stages {

        stage('Build & Test') {
            stages {

                stage('Build') {
                    steps {
                        echo 'Building...'
                    }
                }

                stage('Test') {
                    steps {
                        echo 'Testing...'
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying...'
            }
        }
    }

    post {
        always {
            echo 'Pipeline completed'
        }
    }
}
